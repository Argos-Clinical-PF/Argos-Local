# Puertos locales
FRONTEND_PORT=5173
BACKEND_PORT=8080
POSTGRES_PORT=5432

# PostgreSQL local
POSTGRES_DB=argos_clinical
POSTGRES_USER=argos_app
POSTGRES_PASSWORD=argos_app_local

# Backend Spring Boot
APP_VERSION=0.1.0
DB_MIGRATIONS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_PUBLIC_BASE_URL=http://localhost:5173
ARGOS_TEMAS_PROVIDER=LOCAL
ARGOS_TEMAS_MIN_CONFIDENCE=0.60
ANTHROPIC_TOPICS_MODEL=claude-haiku-4-5
ANTHROPIC_TOPICS_MAX_TOKENS=900

# Email SMTP local para verificacion de cuentas
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=argosclinical@gmail.com
MAIL_PASSWORD=COMPLETAR_APP_PASSWORD_DE_GMAIL
MAIL_FROM=argosclinical@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
EMAIL_VERIFICATION_EXPIRATION_HOURS=24

# Login/JWT local
JWT_SECRET=argos-clinical-local-dev-secret-32-bytes-minimum
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=argos-clinical
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Servicio de transcripcion (faster-whisper)
TRANSCRIPCION_PORT=9000
TRANSCRIPCION_SERVICE_URL=http://transcripcion:9000
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_IDIOMA=es
WHISPER_BEAM_SIZE=3
WHISPER_CPU_THREADS=2

# Servicio de analisis emocional visual
EMOCIONES_PORT=9010
EMOCIONES_SERVICE_URL=http://emociones:9010
EMOCIONES_MODEL_ID=emotiefflib-enet-b0-8-vgaf
EMOCIONES_MOCK=false
EMOCIONES_STRICT_LOAD=true

# Nota clinica asistida (Epica 5 - Claude / Anthropic)
# Conseguila en https://console.anthropic.com/ . Sin esta key la generacion de notas devuelve 503.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cifrado en reposo de transcripciones y notas (ADR-007). En dev el backend usa un
# default si queda vacio; en prod DEBE definirse (va en SSM, nunca en el repo).
ENCRYPTION_KEY=

# Retención temporal de grabaciones (deshabilitada por defecto en local)
RECORDINGS_ENABLED=false
RECORDINGS_BUCKET=
RECORDINGS_KMS_KEY_ID=alias/aws/s3
RECORDINGS_RETENTION_HOURS=12
AWS_REGION=us-east-1

# Frontend Vite
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_ENV=development
CHOKIDAR_USEPOLLING=true
